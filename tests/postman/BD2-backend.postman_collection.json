{
  "info": {
    "name": "BD2 Backend Tests",
    "description": "tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "gateway", "value": "http://localhost:3000" },
    { "key": "inventory", "value": "http://localhost:3001" },
    { "key": "catalog", "value": "http://localhost:3002" }
  ],
  "item": [
    {
      "name": "1. sterownik pg",
      "item": [
        {
          "name": "parameterized update success (PATCH /inventory/:sku)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 1\n}" },
            "url": { "raw": "{{inventory}}/inventory/p001", "host": ["{{inventory}}"], "path": ["inventory", "p001"] },
            "description": "Pula singleton + zapytanie parametryzowane $1,$2. Oczekiwane: 204 No Content. Stock produktu p001 spada o 1."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        },
        {
          "name": "unique violation 23505 -> 409 (POST /api/products)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Duplicate Test\",\n  \"sku\": \"DUPLICATE_TEST_001\",\n  \"price\": 100,\n  \"category_id\": 1,\n  \"long_description\": \"test\"\n}" },
            "url": { "raw": "{{gateway}}/api/products", "host": ["{{gateway}}"], "path": ["api", "products"] },
            "description": "Wyślij DWA RAZY. 1. raz: 201 Created. 2. raz: 409 Conflict z kodem 23505 w details (mapowanie błędu unique violation)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// expect 201 on first call, 409 on subsequent calls",
                  "pm.test('status 201 or 409', () => pm.expect([201, 409]).to.include(pm.response.code));",
                  "if (pm.response.code === 409) {",
                  "  pm.test('details contain pg code 23505', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(JSON.stringify(body)).to.match(/23505/);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "fk violation 23503 -> 400 (POST /api/products)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"FK Test\",\n  \"sku\": \"FK_TEST_001\",\n  \"price\": 50,\n  \"category_id\": 9999,\n  \"long_description\": \"test fk\"\n}" },
            "url": { "raw": "{{gateway}}/api/products", "host": ["{{gateway}}"], "path": ["api", "products"] },
            "description": "category_id=9999 nie istnieje -> Postgres rzuca 23503, middleware mapuje na 400."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));",
                  "pm.test('details contain pg code 23503', () => {",
                  "  pm.expect(JSON.stringify(pm.response.json())).to.match(/23503/);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "param query prevents sql injection (PATCH /inventory/:sku)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 1\n}" },
            "url": {
              "raw": "{{inventory}}/inventory/p001'; DROP TABLE products;--",
              "host": ["{{inventory}}"],
              "path": ["inventory", "p001'; DROP TABLE products;--"]
            },
            "description": "Niebezpieczny SKU jest traktowany jako wartość $2, nie jako część SQL. Oczekiwane: 204, tabela products nadal istnieje."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. knex.js",
      "item": [
        {
          "name": "dynamic WHERE no filters (GET /api/products)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{gateway}}/api/products", "host": ["{{gateway}}"], "path": ["api", "products"] },
            "description": "Brak filtrów -> zwraca wszystkie produkty (200, tablica)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "dynamic WHERE filter category (GET /api/products?category=1)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway}}/api/products?category=1",
              "host": ["{{gateway}}"],
              "path": ["api", "products"],
              "query": [{ "key": "category", "value": "1" }]
            },
            "description": "Filtr po category_id=1 (Earrings). Wszystkie zwrócone produkty mają category_id == 1."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('all items have category_id 1', () => {",
                  "  const items = pm.response.json();",
                  "  items.forEach(p => pm.expect(p.category_id).to.eql(1));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "dynamic WHERE filter maxPrice (GET /api/products?maxPrice=200)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway}}/api/products?maxPrice=200",
              "host": ["{{gateway}}"],
              "path": ["api", "products"],
              "query": [{ "key": "maxPrice", "value": "200" }]
            },
            "description": "Filtr po cenie <=200. Każdy zwrócony produkt ma price <= 200."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('all items price <= 200', () => {",
                  "  pm.response.json().forEach(p => pm.expect(Number(p.price)).to.be.at.most(200));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "dynamic WHERE combined filters (GET /api/products?category=2&maxPrice=500)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway}}/api/products?category=2&maxPrice=500",
              "host": ["{{gateway}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "category", "value": "2" },
                { "key": "maxPrice", "value": "500" }
              ]
            },
            "description": "Oba filtry razem. Wszystkie zwrócone Rings z ceną <=500."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('all items category=2 and price<=500', () => {",
                  "  pm.response.json().forEach(p => {",
                  "    pm.expect(p.category_id).to.eql(2);",
                  "    pm.expect(Number(p.price)).to.be.at.most(500);",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "dynamic WHERE sql injection safe (GET /api/products)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway}}/api/products?category=1' OR '1'='1",
              "host": ["{{gateway}}"],
              "path": ["api", "products"],
              "query": [{ "key": "category", "value": "1' OR '1'='1" }]
            },
            "description": "Wstrzyknięty payload. Oczekiwane: 400 invalid_filter (walidacja na liczbę). Serwis nie pada."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));",
                  "pm.test('response mentions invalid_filter (wrapped by gateway in details)', () => {",
                  "  pm.expect(JSON.stringify(pm.response.json())).to.match(/invalid_filter/);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
