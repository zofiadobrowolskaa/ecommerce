            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"items\": [\n    { \"productId\": 2, \"quantity\": 5, \"price\": 200 },\n    { \"productId\": 3, \"quantity\": -1, \"price\": 50 }\n  ]\n}" },
            "url": { "raw": "{{inventory}}/cart/test-rollback/sync", "host": ["{{inventory}}"], "path": ["cart", "test-rollback", "sync"] },
            "description": "Druga linia ma quantity=-1. Transakcja rzuca i się wycofuje. Oczekiwane: 400."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "rollback verification - cart still has baseline (GET /cart/test-rollback)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{inventory}}/cart/test-rollback", "host": ["{{inventory}}"], "path": ["cart", "test-rollback"] },
            "description": "Po nieudanym sync koszyk ma stare linie. Oczekiwane: 1 linia z setupu (quantity:1, price:100)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
