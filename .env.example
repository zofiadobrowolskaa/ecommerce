# copy this file to .env and adjust if needed

# database credentials
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=ecommerce_db
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password

# host ports exposed by docker compose
API_GATEWAY_PORT=3000
INVENTORY_SERVICE_PORT=3001
CATALOG_SERVICE_PORT=3002
FRONTEND_PORT=5173

# connection strings used by services inside the docker network
MONGO_URI=mongodb://admin:password@mongodb:27017/ecommerce_db?authSource=admin
