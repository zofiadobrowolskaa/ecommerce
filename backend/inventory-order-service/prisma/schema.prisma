datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  // generates typed prisma client during build
  provider = "prisma-client-js"
}

model Order {
  id          Int         @id @default(autoincrement())
  userId      String?     // optional field to support guest checkouts
  totalAmount Decimal     @db.Decimal(10, 2)
  status      String      @default("PENDING")
  lines       OrderLine[]
  createdAt   DateTime    @default(now())

  // compound index for faster user history queries
  @@index([userId, createdAt])
}

model OrderLine {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  sku       String
  price     Decimal @db.Decimal(10, 2) // static price snapshot taken at checkout
  quantity  Int
}